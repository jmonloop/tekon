---
import '../styles/global.css';
import { navLinks, legalLinks, SITE_NAME, DEFAULT_OG_IMAGE_PATH } from './layout-data';
import { SearchBar } from '../components/SearchBar';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
}

const { title, description, ogImage, jsonLd } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage || new URL(DEFAULT_OG_IMAGE_PATH, Astro.site).toString();
---

<html lang="es" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="es-ES" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImageUrl} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />

  <!-- JSON-LD Structured Data -->
  {jsonLd && (
    Array.isArray(jsonLd)
      ? jsonLd.map(schema => (
          <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
        ))
      : <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <slot name="head" />
</head>
<body>
  <!-- Header -->
  <header class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
    <div class="container mx-auto flex h-16 items-center justify-between px-4 md:px-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2" aria-label={`${SITE_NAME} - Inicio`}>
        <img
          src="/images/logo-tekon.png"
          alt={`${SITE_NAME} - Logo`}
          class="h-10 w-auto"
          width="120"
          height="40"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm font-medium text-foreground/80 hover:text-brand transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- SearchBar island (interactive on every page, desktop + mobile) -->
      <div class="flex items-center gap-1">
        <SearchBar client:load />
        <!-- Hamburger: mobile only -->
        <button
          type="button"
          id="menu-toggle"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden p-2 rounded-md text-foreground/70 hover:text-brand transition-colors"
        >
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" x2="20" y1="12" y2="12"/>
            <line x1="4" x2="20" y1="6" y2="6"/>
            <line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
            <path d="M18 6 6 18"/>
            <path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden border-t border-border bg-background"
      role="navigation"
      aria-label="Menú móvil"
    >
      <nav class="container mx-auto flex flex-col px-4 py-4 gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="py-2 px-3 rounded-md text-sm font-medium text-foreground/80 hover:text-brand hover:bg-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border bg-background mt-16">
    <div class="container mx-auto px-4 md:px-6 py-10 md:py-14">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

        <!-- Company info -->
        <div>
          <a href="/" aria-label={`${SITE_NAME} - Inicio`}>
            <img
              src="/images/logo-tekon.png"
              alt={`${SITE_NAME} - Logo`}
              class="h-10 w-auto mb-4"
              width="120"
              height="40"
            />
          </a>
          <address class="not-italic text-sm text-muted-foreground space-y-1">
            <p>S N, Camino Guardarany, 0</p>
            <p>46410 Sueca, Valencia</p>
            <p>
              <a href="tel:+34961705113" class="hover:text-brand transition-colors">96 170 51 13</a>
              <span aria-hidden="true"> · </span>
              <a href="tel:+34638946040" class="hover:text-brand transition-colors">638 946 040</a>
            </p>
            <p>
              <a href="mailto:info@carretillastekon.com" class="hover:text-brand transition-colors">
                info@carretillastekon.com
              </a>
            </p>
          </address>
        </div>

        <!-- Nav links -->
        <div>
          <h3 class="text-sm font-semibold mb-4">Carretillas</h3>
          <ul class="space-y-2">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-brand transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal links -->
        <div>
          <h3 class="text-sm font-semibold mb-4">Legal</h3>
          <ul class="space-y-2">
            {legalLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-brand transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <div class="mt-10 pt-6 border-t border-border text-center text-xs text-muted-foreground">
        <p>© {new Date().getFullYear()} {SITE_NAME}. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <!-- Mobile menu toggle script -->
  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    if (toggle && menu && iconMenu && iconClose) {
      toggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        if (isOpen) {
          menu.classList.add('hidden');
          iconMenu.classList.remove('hidden');
          iconClose.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Abrir menú');
        } else {
          menu.classList.remove('hidden');
          iconMenu.classList.add('hidden');
          iconClose.classList.remove('hidden');
          toggle.setAttribute('aria-expanded', 'true');
          toggle.setAttribute('aria-label', 'Cerrar menú');
        }
      });
    }
  </script>
</body>
</html>
