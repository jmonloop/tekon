---
import Layout from '../../layouts/Layout.astro';
import { ContactFormIsland } from '../../components/ContactFormIsland';
import { supabase } from '../../lib/supabase';
import { localBusinessJsonLd, productJsonLd } from '../../lib/seo';
import type { Forklift, ForkliftSpec, Category } from '../../lib/types';

const PLACEHOLDER_IMAGE = '/images/forklift-placeholder.webp';

// ---- getStaticPaths ----------------------------------------------------------

export async function getStaticPaths() {
  const { data: forklifts, error } = await supabase
    .from('forklifts')
    .select(`
      *,
      categories (*),
      forklift_specs (*)
    `)
    .eq('is_published', true)
    .order('name');

  if (error || !forklifts) {
    console.error('getStaticPaths error:', error);
    return [];
  }

  return forklifts.map((forklift) => ({
    params: { slug: forklift.slug as string },
    props: { forklift },
  }));
}

// ---- Props ------------------------------------------------------------------

interface ForkliftWithRelations extends Forklift {
  categories: Category | null;
  forklift_specs: ForkliftSpec[];
}

interface Props {
  forklift: ForkliftWithRelations;
}

const { forklift } = Astro.props;
const category = forklift.categories;
const specs = [...(forklift.forklift_specs ?? [])].sort(
  (a, b) => a.sort_order - b.sort_order,
);

// ---- SEO -------------------------------------------------------------------

const categoryName = category?.name ?? 'Carretilla';
const titleRaw = `${forklift.name} - ${categoryName} en Valencia | Tekon`;
const title = titleRaw.length > 65
  ? `${forklift.name} en Valencia | Tekon`
  : titleRaw;

const descriptionBase = forklift.short_description
  || (forklift.description ? forklift.description.replace(/<[^>]+>/g, '').slice(0, 120) : categoryName);
const description = `${descriptionBase}. Disponible en Carretillas Tekon, Valencia.`.slice(0, 155);

const jsonLd = [localBusinessJsonLd, productJsonLd({ ...forklift, category })];
const ogImage = forklift.image_url ?? undefined;

// ---- Breadcrumbs ------------------------------------------------------------

const breadcrumbs: { label: string; href?: string }[] = [
  { label: 'Inicio', href: '/' },
];

if (forklift.available_for_sale) {
  breadcrumbs.push({ label: 'Venta de Carretillas', href: '/venta-de-carretillas' });
} else if (forklift.available_for_rental) {
  breadcrumbs.push({ label: 'Alquiler de Carretillas', href: '/alquiler-de-carretillas' });
} else if (forklift.available_as_used) {
  breadcrumbs.push({ label: 'Carretillas de Segunda Mano', href: '/carretillas-de-segunda-mano' });
}

breadcrumbs.push({ label: forklift.name });

// ---- Availability badges ---------------------------------------------------

const availabilityBadges: string[] = [];
if (forklift.available_for_sale) availabilityBadges.push('Venta');
if (forklift.available_for_rental) availabilityBadges.push('Alquiler');
if (forklift.available_as_used) availabilityBadges.push('Segunda mano');
---

<Layout title={title} description={description} ogImage={ogImage} jsonLd={jsonLd}>
  <div class="container mx-auto px-4 md:px-6 py-8 md:py-12 max-w-5xl">

    <!-- Breadcrumb -->
    <nav aria-label="Ruta de navegación" class="mb-6">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground" data-testid="breadcrumb">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-1.5">
            {i > 0 && <span aria-hidden="true" class="text-muted-foreground/50">/</span>}
            {crumb.href ? (
              <a href={crumb.href} class="hover:text-brand transition-colors">
                {crumb.label}
              </a>
            ) : (
              <span class="text-foreground font-medium" aria-current="page">{crumb.label}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">

      <!-- Left: image -->
      <div>
        <div class="aspect-[4/3] overflow-hidden rounded-xl bg-muted shadow-sm" data-testid="forklift-image-container">
          <img
            src={forklift.image_url ?? PLACEHOLDER_IMAGE}
            alt={`${forklift.name} - ${categoryName} en Valencia`}
            width={800}
            height={600}
            class="h-full w-full object-cover"
            loading="eager"
            data-testid="forklift-image"
          />
        </div>

        <!-- PDF download -->
        {forklift.catalog_pdf_url && (
          <a
            href={forklift.catalog_pdf_url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 flex items-center gap-2 text-sm font-medium text-brand hover:underline"
            data-testid="pdf-download-link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Descargar ficha técnica (PDF)
          </a>
        )}
      </div>

      <!-- Right: info -->
      <div class="flex flex-col gap-6">
        <!-- Category badge -->
        {category && (
          <span
            class="inline-flex w-fit items-center rounded-full border border-brand/30 bg-brand/10 px-3 py-1 text-xs font-semibold text-brand"
            data-testid="category-badge"
          >
            {category.name}
          </span>
        )}

        <h1 class="text-3xl font-bold tracking-tight" data-testid="forklift-name">
          {forklift.name}
        </h1>

        {forklift.short_description && (
          <p class="text-muted-foreground text-lg leading-relaxed" data-testid="short-description">
            {forklift.short_description}
          </p>
        )}

        <!-- Availability -->
        {availabilityBadges.length > 0 && (
          <div class="flex flex-wrap gap-2" data-testid="availability-badges">
            {availabilityBadges.map(badge => (
              <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                {badge}
              </span>
            ))}
          </div>
        )}

        <!-- Specs table -->
        {specs.length > 0 && (
          <div data-testid="specs-table">
            <h2 class="mb-3 text-base font-semibold">Especificaciones técnicas</h2>
            <div class="overflow-hidden rounded-lg border border-border">
              <table class="w-full text-sm">
                <tbody>
                  {specs.map((spec, i) => (
                    <tr class={i % 2 === 0 ? 'bg-muted/40' : 'bg-background'}>
                      <td class="px-4 py-2.5 font-medium text-foreground/80 w-1/2">
                        {spec.spec_name}
                      </td>
                      <td class="px-4 py-2.5 text-foreground">
                        {spec.spec_value}{spec.spec_unit ? ` ${spec.spec_unit}` : ''}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Full description -->
    {forklift.description && (
      <div class="mt-10" data-testid="full-description">
        <h2 class="mb-4 text-xl font-semibold">Descripción</h2>
        <div
          class="prose prose-neutral max-w-none"
          set:html={forklift.description}
        />
      </div>
    )}

    <!-- Contact form -->
    <div class="mt-12 rounded-xl border border-border bg-card p-6 md:p-8" data-testid="contact-section">
      <ContactFormIsland
        client:visible
        forkliftId={forklift.id}
        forkliftName={forklift.name}
      />
    </div>

  </div>
</Layout>
