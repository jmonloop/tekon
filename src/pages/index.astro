---
import Layout from '../layouts/Layout.astro';

const title = 'Carretillas Tekon - Venta, Alquiler y Reparacion de Carretillas en Valencia';
const description =
  'Venta, alquiler y reparacion de carretillas elevadoras en Valencia y provincia. Desde 1989. Contacta con Tekon.';
---

<Layout title={title} description={description}>
  <div class="container mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl font-bold mb-4">Venta, Alquiler y Servicio de Carretillas Elevadoras en Valencia</h1>
    <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
      Descubre nuestra selección de carretillas elevadoras en Valencia. Apiladores eléctricos,
      transpaletas, carretillas contrapesadas y montacargas. Desde 1989.
    </p>
  </div>
</Layout>
