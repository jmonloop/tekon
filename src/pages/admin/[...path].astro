---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerClient } from '../../lib/supabase';

export async function getStaticPaths() {
  const staticPaths = [
    undefined,
    'carretillas',
    'carretillas/nueva',
    'categorias',
    'consultas',
  ];

  async function fetchForkliftPaths(): Promise<string[]> {
    try {
      const supabase = createServerClient();
      const { data: forklifts } = await supabase.from('forklifts').select('id');
      return (forklifts ?? []).map(({ id }) => `carretillas/${id}`);
    } catch {
      return [];
    }
  }

  const forkliftPaths = await fetchForkliftPaths();
  return [...staticPaths, ...forkliftPaths].map((path) => ({ params: { path } }));
}
---

<AdminLayout />
